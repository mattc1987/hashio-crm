# Hashio CRM — environment
# Copy this to `.env.local` and fill in your values.

# Google Sheet ID (default = the one Cowork built)
VITE_SHEET_ID=1kHn4GA2YB5LyBImxMqhwDBF374gjqOOoNpr7LeBRHoQ

# Apps Script web app URL (after deploying apps-script/Code.gs — see SETUP.md)
# Leave blank to run in read-only mode with queued writes.
VITE_APPS_SCRIPT_URL=

# Apps Script API key (the one setupApiKey() logged in the Apps Script editor)
VITE_APPS_SCRIPT_KEY=
